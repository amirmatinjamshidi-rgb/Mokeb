# Copy to .env.local and adjust as needed.

# Server-only backend origin used by Next.js rewrite and SSR fetches.
# Example: http://45.94.213.105
API_URL=

# Optional explicit swagger URL for dev pages.
# Example: http://45.94.213.105/swagger/index.html
SWAGGER_URL=

# Comma-separated hosts allowed to load Next.js dev assets (HMR, etc.) over LAN IP.
# Required when opening the app as http://10.210.10.45:3000 instead of localhost.
ALLOWED_DEV_ORIGINS=10.210.10.45

